{
  "owner": "itsjustatank",
  "allow_owner_authored": true,
  "max_file_pages": 50,
  "max_review_pages": 50,
  "protected_file_names": [
    "AGENTS.md",
    "CLAUDE.md",
    "GEMINI.md",
    "CONVENTIONS.md",
    ".cursorrules",
    ".clinerules",
    ".windsurfrules",
    "package.json",
    "package-lock.json",
    "pnpm-lock.yaml",
    "yarn.lock",
    "Dockerfile",
    "docker-compose.yml",
    "Caddyfile",
    ".dockerignore"
  ],
  "protected_prefixes": [
    ".github/",
    "scripts/",
    "tools/",
    "patches/",
    "src/js/",
    "src/vendor/"
  ],
  "protected_globs": [
    "**/AGENTS.md",
    "**/*.html",
    "**/*.htm"
  ]
}
